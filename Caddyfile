# Co-hosted sites (e.g. bluelight.ventures) drop their own *.caddy site files
# into ./sites, mounted at /etc/caddy/sites. This directory is NOT overwritten
# by release/deploy.sh, so other apps on this host manage their own routing
# and TLS independently of TagNote. A reload picks up new files with no
# downtime for the sites already running.
import /etc/caddy/sites/*.caddy

{$TAGNOTE_DOMAIN:example.com} {
	# Grafana reverse proxy (keep the /grafana prefix)
	handle /grafana/* {
		reverse_proxy grafana:3000
	}
	handle /grafana {
		reverse_proxy grafana:3000
	}

	reverse_proxy tagnote:3000
	encode gzip zstd

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
	}

	log {
		output stdout
		format json
	}
}

www.{$TAGNOTE_DOMAIN:example.com} {
	redir https://{$TAGNOTE_DOMAIN:example.com}{uri} permanent
}
